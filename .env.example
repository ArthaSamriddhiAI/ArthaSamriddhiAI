# Database
DATABASE_URL=sqlite+aiosqlite:///./artha.db

# LLM Providers
# Default provider handles all standard agent calls
DEFAULT_LLM_PROVIDER=mistral
MISTRAL_API_KEY=...

# Claude is used for complex tasks only (synthesis, CPR, ISE)
# SmartLLMRouter routes to Claude when provider_hint="claude" is set
# If not configured, falls back to default provider
ANTHROPIC_API_KEY=sk-ant-...

# Optional
OPENAI_API_KEY=sk-...

# Application
LOG_LEVEL=INFO
ENVIRONMENT=development
