# Database
DATABASE_URL=sqlite+aiosqlite:///./artha.db

# LLM Providers
# Default provider handles all standard agent calls
DEFAULT_LLM_PROVIDER=mistral
MISTRAL_API_KEY=...

# Claude is used for complex tasks only (synthesis, CPR, ISE)
# SmartLLMRouter routes to Claude when provider_hint="claude" is set
# If not configured, falls back to default provider
ANTHROPIC_API_KEY=sk-ant-...

# Optional
OPENAI_API_KEY=sk-...

# Application
LOG_LEVEL=INFO
ENVIRONMENT=development

# ---------------- Cluster 0: Authentication & Sessions ----------------
# JWT signing key (HS256 by default). Required for non-development
# environments. In dev, leave empty for an auto-generated per-process
# secret (tokens become invalid across backend restarts).
# Generate one with:  python -c "import secrets; print(secrets.token_urlsafe(48))"
JWT_SECRET=
